<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="ekgGrad" x1="0" y1="0" x2="1200" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#56f6c8" stop-opacity="0"/>
      <stop offset="15%" stop-color="#56f6c8" stop-opacity="1"/>
      <stop offset="85%" stop-color="#5cd0ff" stop-opacity="1"/>
      <stop offset="100%" stop-color="#5cd0ff" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="badgeGrad" x1="0" y1="0" x2="100" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#56f6c8"/>
      <stop offset="100%" stop-color="#5cd0ff"/>
    </linearGradient>
    <radialGradient id="glow1" cx="50%" cy="0%" r="60%" fx="50%" fy="0%">
      <stop offset="0%" stop-color="#56f6c8" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#56f6c8" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="glow2" cx="90%" cy="100%" r="50%">
      <stop offset="0%" stop-color="#5cd0ff" stop-opacity="0.1"/>
      <stop offset="100%" stop-color="#5cd0ff" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="#0b1120"/>
  <rect width="1200" height="630" fill="url(#glow1)"/>
  <rect width="1200" height="630" fill="url(#glow2)"/>

  <!-- EKG Badge -->
  <rect x="340" y="215" width="100" height="100" rx="22" fill="#0f172e" stroke="rgba(255,255,255,0.1)" stroke-width="2"/>
  <path d="M350 265 L366 265 L372 253 L378 233 L385 293 L391 249 L397 265 L430 265"
        stroke="url(#badgeGrad)" stroke-width="5" fill="none"
        stroke-linecap="round" stroke-linejoin="round"/>

  <!-- MY label -->
  <text x="462" y="248"
        font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
        font-size="16" font-weight="700" letter-spacing="4"
        fill="rgba(255,255,255,0.4)">MY</text>

  <!-- PaceZone wordmark -->
  <text x="460" y="320"
        font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
        font-size="80" font-weight="800" letter-spacing="-2">
    <tspan fill="#ffffff">Pace</tspan><tspan fill="#56f6c8">Zone</tspan>
  </text>

  <!-- Tagline -->
  <text x="600" y="388"
        font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
        font-size="22" font-weight="400" letter-spacing="1"
        fill="rgba(255,255,255,0.45)" text-anchor="middle">Train smarter. Race confident.</text>

  <!-- Decorative EKG line -->
  <path d="M0 530 L240 530 L280 530 L310 510 L330 550 L350 500 L370 560 L390 530 L430 530 L1200 530"
        stroke="url(#ekgGrad)" stroke-width="2" fill="none" opacity="0.35"
        stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Beta pill -->
  <rect x="916" y="28" width="168" height="34" rx="17" fill="rgba(86,246,200,0.12)" stroke="rgba(86,246,200,0.25)" stroke-width="1"/>
  <text x="1000" y="51"
        font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
        font-size="12" font-weight="700" letter-spacing="2"
        fill="#56f6c8" text-anchor="middle">BETA — INVITE ONLY</text>

  <!-- URL -->
  <text x="1164" y="608"
        font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
        font-size="14" font-weight="500" letter-spacing="1"
        fill="rgba(255,255,255,0.2)" text-anchor="end">mypacezone.com</text>
</svg>
